---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Leftist gaming Discord: Marathon, anti-fascist, queer, mutual care. Bigots get removed.'
} = Astro.props;

const canonicalHref = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : null;
const ogImageHref = Astro.site ? new URL('/da-logo.svg', Astro.site).href : null;
---
<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#0a0907" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_GB" />
    {ogImageHref && <meta property="og:image" content={ogImageHref} />}
    {ogImageHref && <meta property="og:image:alt" content="Direct Action logo" />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImageHref && <meta name="twitter:image" content={ogImageHref} />}
    {canonicalHref && <link rel="canonical" href={canonicalHref} />}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/da-logo.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Antonio:wght@400;600;700&family=Bungee&family=JetBrains+Mono:wght@300;400;500;700&family=VT323&display=swap"
      rel="stylesheet"
    />
    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <slot />
  </body>
</html>
