---
import { isD2ColorIcon } from '../../lib/d2-assets.ts';

interface Props {
  src: string;
  alt?: string;
  size?: number;
  decorative?: boolean;
}

const { src, alt = '', size = 32, decorative = true } = Astro.props;
const color = isD2ColorIcon(src);
---
{
  color ? (
    <img
      class="d2-icon d2-icon--color"
      src={src}
      alt={decorative ? '' : alt}
      width={size}
      height={size}
      decoding="async"
      aria-hidden={decorative ? 'true' : undefined}
    />
  ) : (
    <span
      class="d2-icon d2-icon--mask"
      style={`--d2-icon-url: url(${src}); width: ${size}px; height: ${size}px`}
      role={decorative ? undefined : 'img'}
      aria-label={decorative ? undefined : alt}
      aria-hidden={decorative ? 'true' : undefined}
    />
  )
}
