---
import Base from '../layouts/Base.astro';
import TopBar from '../components/TopBar.astro';
import Footer from '../components/Footer.astro';
import SectionLabel from '../components/SectionLabel.astro';
import SectionTitle from '../components/SectionTitle.astro';
import DoctrineRow from '../components/DoctrineRow.astro';
import { CLAN_SITE_URL, DISCORD_INVITE } from '../constants.ts';
import doctrineData from '../data/doctrine.json';

const summary = doctrineData.tenets.slice(0, 4);
const steps = [
  {
    sym: '01',
    title: 'Hop in',
    body: 'One link, straight in. Say hello when you feel like it.'
  },
  {
    sym: '02',
    title: 'Look around',
    body: 'Skim the channels. Introduce yourself if you want — totally optional.'
  },
  {
    sym: '03',
    title: 'Mic up',
    body: 'Most games need a mic. Push-to-talk helps. Mic off today? Say so in text.'
  },
  {
    sym: '04',
    title: 'Play',
    body: 'Check pings or ask who is on. New players get a hand; regulars fold you in.'
  }
] as const;
const siteHref = Astro.site?.href ?? `${CLAN_SITE_URL}/`;
const joinFaqs = [
  {
    question: 'What is Direct Action Clan?',
    answer:
      'Direct Action Clan is a leftist, anti-fascist gaming Discord community with a strong Marathon focus and a wider multiplayer game rotation.'
  },
  {
    question: 'Do I need a microphone to join?',
    answer:
      'You can join without speaking straight away, but most sessions use voice chat. A basic mic and push-to-talk are enough to get started.'
  },
  {
    question: 'Who is welcome in this server?',
    answer:
      'We welcome players who support anti-racist, anti-fascist, and LGBTQ-inclusive spaces. Mutual respect is a hard requirement.'
  }
] as const;
const joinSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Home',
        item: siteHref
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Join',
        item: new URL('/join', siteHref).href
      }
    ]
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: joinFaqs.map((faq) => ({
      '@type': 'Question',
      name: faq.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: faq.answer
      }
    }))
  }
];
---
<Base
  title="Join Direct Action Clan | Leftist Discord for Marathon Players"
  description="Join Direct Action Clan on Discord. Learn how voice comms work, what to expect on your first night, and how our anti-fascist community plays together."
  schema={joinSchema}
>
  <TopBar />
  <main id="main-content">
    <section class="section" aria-labelledby="join-title">
      <div class="wrap">
        <SectionLabel code="JOIN" text="Join us" />
        <SectionTitle id="join-title">Glad you're <span class="accent">here.</span></SectionTitle>
        <p class="join-lead">
          <strong>Anarchist, anti-fascist, anti-racist, LGBTQ-friendly.</strong> Mutual respect is our baseline. If that sounds like you, come on in and play.
        </p>
        <div class="join-cta-row">
          <a href={DISCORD_INVITE} class="cta-primary" rel="noopener noreferrer">
            Open Discord
            <span class="arrow">→</span>
          </a>
        </div>

        <h2 class="join-section-title">
          Your first <span class="cyan">night.</span>
        </h2>
        <p class="join-lead">
          Text chat gets busy; voice is calmer. People may ask what you play and where you are. <strong>Say what you want.</strong>
        </p>

        <ol class="join-steps">
          {
            steps.map((s) => (
              <li class="join-step">
                <span class="join-step-mark" aria-hidden="true">{s.sym}</span>
                <div class="join-step-body">
                  <span class="step-num">Step // {s.sym}</span>
                  <h3>{s.title}</h3>
                  <p>{s.body}</p>
                </div>
              </li>
            ))
          }
        </ol>

        <p class="join-mic-note">
          <strong>No fancy gear needed.</strong> Clear audio and a willingness to talk beats an expensive headset.
        </p>

        <h2 class="join-section-title spaced">
          What we're about <span class="accent">(doctrine)</span>
        </h2>
        <p class="doctrine-preamble">
          Longer read: <a href="/doctrine" class="link-acid">/doctrine</a>. If this feels right, you'll fit right in.
        </p>
        <div class="doctrine-stack">
          {
            summary.map((t) => (
              <DoctrineRow
                num={t.num}
                tenet={t.tenet}
                headline={t.headline}
                bodyHtml={t.bodyHtml}
              />
            ))
          }
        </div>
        <section class="join-faq" aria-labelledby="join-faq-title">
          <h2 class="join-section-title" id="join-faq-title">
            Quick answers
          </h2>
          {
            joinFaqs.map((faq) => (
              <article class="join-faq-item">
                <h3>{faq.question}</h3>
                <p>{faq.answer}</p>
              </article>
            ))
          }
        </section>
      </div>
    </section>
  </main>
  <Footer />
</Base>
