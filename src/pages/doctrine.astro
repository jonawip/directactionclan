---
import Base from '../layouts/Base.astro';
import TopBar from '../components/TopBar.astro';
import Footer from '../components/Footer.astro';
import SectionLabel from '../components/SectionLabel.astro';
import SectionTitle from '../components/SectionTitle.astro';
import DoctrineRow from '../components/DoctrineRow.astro';
import doctrineData from '../data/doctrine.json';
const siteHref = Astro.site?.href ?? 'https://directactionclan.com/';
const doctrineSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: siteHref
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Doctrine',
      item: new URL('/doctrine', siteHref).href
    }
  ]
};
---
<Base
  title="Community Doctrine | Direct Action Clan Gaming Values"
  description="Read the Direct Action Clan doctrine: anti-fascist community standards, solidarity rules, voice chat culture, and safety expectations."
  schema={doctrineSchema}
>
  <TopBar />
  <main id="main-content">
    <section class="section" aria-labelledby="doctrine-page-title">
      <div class="wrap">
        <SectionLabel code="DOC" text="Doctrine" />
        <SectionTitle id="doctrine-page-title">How we <span class="accent">work.</span></SectionTitle>
        <p class="doctrine-preamble" set:html={doctrineData.preambleHtml} />
        <div class="doctrine-stack">
          {
            doctrineData.tenets.map((t) => (
              <DoctrineRow
                num={t.num}
                tenet={t.tenet}
                headline={t.headline}
                bodyHtml={t.bodyHtml}
              />
            ))
          }
        </div>
        <aside class="doctrine-callout" aria-labelledby="callout-title">
          <h3 id="callout-title">{doctrineData.callout.title}</h3>
          {
            doctrineData.callout.paragraphsHtml.map((p) => (
              <p set:html={p} />
            ))
          }
        </aside>
      </div>
    </section>
  </main>
  <Footer />
</Base>
