---
export const prerender = false;

import Base from '../layouts/Base.astro';
import TopBar from '../components/TopBar.astro';
import Hero from '../components/Hero.astro';
import Manifesto from '../components/Manifesto.astro';
import SectionLabel from '../components/SectionLabel.astro';
import SectionTitle from '../components/SectionTitle.astro';
import BriefingCard from '../components/BriefingCard.astro';
import DoctrineRow from '../components/DoctrineRow.astro';
import TransmissionFeed from '../components/TransmissionFeed.astro';
import RotationItem from '../components/RotationItem.astro';
import DeployCTA from '../components/DeployCTA.astro';
import Footer from '../components/Footer.astro';
import GoodbyeD2Hero from '../components/goodbye-d2/GoodbyeD2Hero.astro';
import HeroLead from '../components/goodbye-d2/HeroLead.astro';
import GoodbyeD2Briefing from '../components/goodbye-d2/GoodbyeD2Briefing.astro';
import D2WeekCalendar from '../components/goodbye-d2/D2WeekCalendar.astro';
import GoodbyeD2Rotation from '../components/goodbye-d2/GoodbyeD2Rotation.astro';
import doctrineData from '../data/doctrine.json';
import rotationData from '../data/rotation.json';
import { goodbyeD2Copy } from '../data/goodbye-d2-copy.ts';
import { goodbyeD2TransmissionLines } from '../data/goodbye-d2-transmission.ts';
import { isGoodbyeD2Active } from '../lib/goodbye-d2.ts';
import { fetchD2WeekSessions } from '../lib/d2-week-games.ts';
import '../styles/goodbye-d2.css';
import { CLAN_SITE_URL } from '../constants.ts';

const goodbyeD2 = isGoodbyeD2Active();

const homeDoctrine = doctrineData.tenets.slice(0, 4);
const rotationItems = rotationData.games.map((g, i) => ({
  num: `/0${i + 1}`,
  name: g.name,
  tag: g.tag
}));

const d2Sessions = goodbyeD2 ? await fetchD2WeekSessions() : [];

const siteHref = Astro.site?.href ?? `${CLAN_SITE_URL}/`;

const marathonTitle = 'Direct Action Clan | Leftist Marathon Discord Community';
const marathonDescription =
  'Join Direct Action Clan, a leftist Marathon Discord server focused on anti-fascist values, inclusive voice comms, and co-op multiplayer.';

const d2Title = goodbyeD2Copy.seo.title;
const d2Description = goodbyeD2Copy.seo.description;

const homeSchema = goodbyeD2
  ? [
      {
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: 'Direct Action Clan',
        url: siteHref,
        inLanguage: 'en-GB',
        description: d2Description
      },
      {
        '@context': 'https://schema.org',
        '@type': 'Organization',
        name: 'Direct Action Clan',
        url: siteHref,
        sameAs: ['https://discord.gg/directaction'],
        description:
          'Anti-fascist, queer-inclusive gaming community marking the end of Destiny 2 live development.'
      }
    ]
  : [
      {
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: 'Direct Action Clan',
        url: siteHref,
        inLanguage: 'en-GB',
        description: 'Leftist gaming Discord community for Marathon and cooperative multiplayer games.'
      },
      {
        '@context': 'https://schema.org',
        '@type': 'Organization',
        name: 'Direct Action Clan',
        url: siteHref,
        sameAs: ['https://discord.gg/directaction'],
        description:
          'Anti-fascist, queer-inclusive gaming community with a focus on co-op play and mutual care.'
      }
    ];
---
<Base
  title={goodbyeD2 ? d2Title : marathonTitle}
  description={goodbyeD2 ? d2Description : marathonDescription}
  ogImage={goodbyeD2 ? '/goodbye-d2/hero-desktop.jpg' : undefined}
  ogImageAlt={goodbyeD2 ? goodbyeD2Copy.seo.ogImageAlt : undefined}
  schema={homeSchema}
>
  {
    goodbyeD2 && (
      <Fragment slot="head">
        <link
          rel="preload"
          as="image"
          type="image/webp"
          href="/goodbye-d2/hero-desktop.webp"
          imagesrcset="/goodbye-d2/hero-desktop.webp 1x, /goodbye-d2/hero-desktop@2x.webp 2x"
          media="(min-width: 768px)"
          fetchpriority="high"
        />
        <link
          rel="preload"
          as="image"
          href="/goodbye-d2/hero-mobile.png"
          media="(max-width: 767px)"
          fetchpriority="high"
        />
      </Fragment>
    )
  }
  <TopBar />
  <main id="main-content">
    {
      goodbyeD2 ? (
        <div class="d2-takeover">
          <GoodbyeD2Hero />
          <HeroLead />
          <section class="section d2-section" id="briefing" aria-labelledby="briefing-title">
            <div class="wrap">
              <SectionLabel
                code={goodbyeD2Copy.sections.finalOp.code}
                text={goodbyeD2Copy.sections.finalOp.label}
              />
              <SectionTitle id="briefing-title">
                {goodbyeD2Copy.sections.finalOp.title}
                <span class="accent">{goodbyeD2Copy.sections.finalOp.titleAccent}</span>
              </SectionTitle>
              <GoodbyeD2Briefing />
            </div>
          </section>
          <section class="section d2-section" aria-labelledby="the-week-title">
            <div class="wrap">
              <SectionLabel
                code={goodbyeD2Copy.sections.week.code}
                text={goodbyeD2Copy.sections.week.label}
              />
              <SectionTitle id="the-week-title">
                {goodbyeD2Copy.sections.week.title}
                <span class="accent">{goodbyeD2Copy.sections.week.titleAccent}</span>
              </SectionTitle>
              <D2WeekCalendar sessions={d2Sessions} />
            </div>
          </section>
          <section class="section d2-section" id="transmission" aria-labelledby="transmission-title">
            <div class="wrap">
              <SectionLabel
                code={goodbyeD2Copy.sections.wire.code}
                text={goodbyeD2Copy.sections.wire.label}
              />
              <SectionTitle id="transmission-title">
                {goodbyeD2Copy.sections.wire.title}
                <span class="cyan">{goodbyeD2Copy.sections.wire.titleAccent}</span>
              </SectionTitle>
              <TransmissionFeed lines={goodbyeD2TransmissionLines} />
            </div>
          </section>
          <section class="section d2-section" id="rotation" aria-labelledby="rotation-title">
            <div class="wrap">
              <SectionLabel
                code={goodbyeD2Copy.sections.rotation.code}
                text={goodbyeD2Copy.sections.rotation.label}
              />
              <SectionTitle id="rotation-title">
                {goodbyeD2Copy.sections.rotation.title}
                <span class="accent">{goodbyeD2Copy.sections.rotation.titleAccent}</span>
              </SectionTitle>
              <GoodbyeD2Rotation />
            </div>
          </section>
        </div>
      ) : (
        <>
          <Hero />
          <Manifesto />
          <section class="section" id="briefing" aria-labelledby="briefing-title">
            <div class="wrap">
              <SectionLabel code="01" text="Main game" />
              <SectionTitle id="briefing-title">
                Playing <span class="accent">now.</span>
              </SectionTitle>
              <BriefingCard />
            </div>
          </section>
          <section class="section" id="doctrine" aria-labelledby="doctrine-title">
            <div class="wrap">
              <SectionLabel code="02" text="Values" />
              <SectionTitle id="doctrine-title">
                What we <span class="accent">mean.</span>
              </SectionTitle>
              <div class="doctrine-stack">
                {homeDoctrine.map((t) => (
                  <DoctrineRow
                    num={t.num}
                    tenet={t.tenet}
                    headline={t.headline}
                    bodyHtml={t.bodyHtml}
                  />
                ))}
              </div>
            </div>
          </section>
          <section class="section" id="transmission" aria-labelledby="transmission-title">
            <div class="wrap">
              <SectionLabel code="03" text="Live feed" />
              <SectionTitle id="transmission-title">
                On the <span class="cyan">wire.</span>
              </SectionTitle>
              <TransmissionFeed />
            </div>
          </section>
          <section class="section" id="rotation" aria-labelledby="rotation-title">
            <div class="wrap">
              <SectionLabel code="04" text="Also playing" />
              <SectionTitle id="rotation-title">
                More <span class="accent">games.</span>
              </SectionTitle>
              <div class="rotation">
                <div class="rotation-intro">
                  <p set:html={rotationData.introHtml} />
                </div>
                <div class="rotation-list">
                  {rotationItems.map((item) => <RotationItem {...item} />)}
                </div>
              </div>
            </div>
          </section>
        </>
      )
    }
    <DeployCTA />
  </main>
  <Footer />
</Base>
